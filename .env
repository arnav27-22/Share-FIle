# FlowShare Environment Configuration

# Server & Auth
PORT=3000
NEXTAUTH_SECRET="flowshare_super_secret_jwt_encryption_key_2026"
JWT_SECRET="flowshare_jwt_token_secret_key_prod_ready"

# Database
DATABASE_URL="file:./dev.db"

# Storage Driver (local, s3, r2, b2)
STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH="./uploads"

# S3 / Cloudflare R2 / Backblaze B2 Compatible Settings (Optional)
S3_ENDPOINT="https://s3.us-east-1.amazonaws.com"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="flowshare-files"

# Redis & Rate Limiting (Optional - fallback to memory store if unconfigured)
REDIS_URL="redis://localhost:6379"

# Security & Malware Scanning
ENABLE_MALWARE_SCAN=false
CLAMAV_HOST="localhost"
CLAMAV_PORT=3310
